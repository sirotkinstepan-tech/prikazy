APP_NAME=prikazy
APP_ENV=local
APP_DEBUG=true
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=postgresql+psycopg://prikazy:prikazy@postgres:5432/prikazy
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=documents
S3_REGION=us-east-1
S3_USE_SSL=false

MAX_UPLOAD_SIZE_BYTES=52428800
ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,image/tiff,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
DEFAULT_OCR_PROVIDER=stub

# AI-запросы к базе через Yandex Cloud Foundation Models
LLM_PROVIDER=yandex
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt-lite/latest
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOOL_ROUNDS=5
LLM_MAX_OUTPUT_TOKENS=2000
AUTH_REQUIRED_FOR_AI=true

# Альтернатива: OpenAI-compatible API
# LLM_PROVIDER=openai
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini

