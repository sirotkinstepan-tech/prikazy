APP_NAME=prikazy
APP_ENV=local
APP_DEBUG=false
DOCS_ENABLED=true
CSRF_ENABLED=true
SESSION_HTTPS_ONLY=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_UPLOAD_PER_MINUTE=30
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

# Base URL for links in API responses (browser/curl on the host machine)
PUBLIC_API_BASE_URL=http://localhost:8001
# Production with domain + nginx + Let's Encrypt:
# PUBLIC_API_BASE_URL=https://kmk-base.ru
# SESSION_HTTPS_ONLY=true

# --- Docker Compose (default for `make up`) ---
DATABASE_URL=postgresql+psycopg://prikazy:prikazy@postgres:5432/prikazy
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
S3_ENDPOINT_URL=http://minio:9000

# --- API/worker on host, infra in Docker (`make local-up` / published ports) ---
# DATABASE_URL=postgresql+psycopg://prikazy:prikazy@localhost:5433/prikazy
# CELERY_BROKER_URL=redis://localhost:6380/0
# CELERY_RESULT_BACKEND=redis://localhost:6380/1
# S3_ENDPOINT_URL=http://localhost:9002

S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=documents
S3_REGION=us-east-1
S3_USE_SSL=false

MAX_UPLOAD_SIZE_BYTES=52428800
ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,image/tiff,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
DEFAULT_OCR_PROVIDER=tesseract
OCR_TESSERACT_LANGUAGES=rus+eng
OCR_TESSERACT_DPI_SCALE=2.0
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-in-production-use-a-long-random-string

# AI-запросы к базе через Yandex Cloud Foundation Models
LLM_PROVIDER=yandex
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt-lite/latest
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOOL_ROUNDS=5
LLM_MAX_OUTPUT_TOKENS=2000
AI_MONTHLY_QUERY_LIMIT=100
AI_DOCUMENT_TEXT_MAX_CHARS=12000

# Альтернатива: OpenAI-compatible API
# LLM_PROVIDER=openai
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini

# Production checklist:
# APP_ENV=production
# APP_DEBUG=false
# DOCS_ENABLED=true
# SESSION_HTTPS_ONLY=true
# SESSION_SECRET=<long random>
